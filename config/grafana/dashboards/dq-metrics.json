          "rawSql": "WITH stats AS (\n  SELECT platform,\n    AVG(rating) AS avg_r, NULLIF(STDDEV(rating), 0) AS std_r,\n    AVG(review_count::numeric) AS avg_rc, NULLIF(STDDEV(review_count), 0) AS std_rc\n  FROM platform_merchants\n  GROUP BY platform\n)\nSELECT pm.platform AS \"Platform\", COUNT(*) AS \"Anomaly count\"\nFROM platform_merchants pm\nJOIN stats s ON s.platform = pm.platform\nWHERE (pm.rating IS NOT NULL AND s.std_r IS NOT NULL AND ABS(pm.rating - s.avg_r) / s.std_r > 2)\n   OR (pm.review_count IS NOT NULL AND s.std_rc IS NOT NULL AND ABS(pm.review_count - s.avg_rc) / s.std_rc > 2)\nGROUP BY pm.platform\nORDER BY \"Anomaly count\" DESC;",
