          "rawQuery": true,
          "rawSql": "WITH totals AS (\n  SELECT COUNT(*) as total FROM platform_merchants\n),\nmissing AS (\n  SELECT COUNT(*) as cnt FROM platform_merchants WHERE address IS NULL OR trim(address) = ''\n)\nSELECT \n  ROUND(GREATEST(0, (totals.total - missing.cnt)::numeric / NULLIF(totals.total, 0) * 100), 2) AS \"Completeness Score %\"\nFROM totals, missing;",
