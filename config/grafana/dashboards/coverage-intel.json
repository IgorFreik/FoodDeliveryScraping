          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    pm.name AS \"Merchant Name\",\n    pm.platform AS \"Platform\",\n    pm.market AS \"Market\",\n    pm.rating AS \"Rating\",\n    pm.review_count AS \"Review Count\",\n    (COALESCE(pm.rating, 0) * LN(COALESCE(pm.review_count, 1) + 1))::numeric(10,1) AS \"Quality Score\"\nFROM platform_merchants pm\nLEFT JOIN merchant_matches mm ON mm.platform_merchant_id = pm.id\nLEFT JOIN merchants m ON m.id = mm.merchant_id\nWHERE pm.platform != 'ubereats'\n  AND (m.is_on_our_platform = FALSE OR m.id IS NULL)\nORDER BY \"Quality Score\" DESC\nLIMIT 100;",
          "refId": "A",
          "sql": {
