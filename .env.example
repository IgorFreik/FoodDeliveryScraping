# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=scraper123

# ── MinIO (S3-compatible) ────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ── Airflow ──────────────────────────────────────────────────────────
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Change in production! Use a strong random string.
AIRFLOW_SECRET_KEY=supersecretkey

# ── Bright Data Proxy (optional — leave blank to scrape direct) ──────
BRIGHTDATA_PROXY_HOST=
BRIGHTDATA_PROXY_PORT=
BRIGHTDATA_PROXY_USER=
BRIGHTDATA_PROXY_PASS=
# Alternative: Scraping Browser (remote Playwright via CDP)
BRIGHTDATA_BROWSER_URL=

# ── Google Maps Geocoding (optional) ─────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Slack Alerts (optional) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=
