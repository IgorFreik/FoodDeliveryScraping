          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  platform AS \"Platform\",\n  COUNT(*) FILTER (WHERE address IS NULL OR trim(address) = '') AS \"Missing address\",\n  COUNT(*) FILTER (WHERE (address IS NOT NULL AND trim(address) != '') AND address !~ '[0-9]{4}\\s*[A-Z]{0,2}\\y') AS \"Missing postal\",\n  COUNT(*) FILTER (WHERE (address IS NOT NULL AND trim(address) != '') AND address ~ '[0-9]{4}\\s*[A-Z]{0,2}\\y' AND (trim(coalesce(substring(address from '[0-9]{4}\\s*[A-Z]{0,2}\\s*,?\\s*(.+)$'), '')) = '')) AS \"Missing city\"\nFROM platform_merchants\nGROUP BY platform\nORDER BY platform;",
          "refId": "A",
