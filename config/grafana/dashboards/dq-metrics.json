          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT p.platform, COALESCE(m.cnt, 0)::bigint AS \"Missing Address\"\nFROM (SELECT DISTINCT platform FROM platform_merchants) p\nLEFT JOIN (\n  SELECT platform, COUNT(*) AS cnt\n  FROM platform_merchants\n  WHERE address IS NULL OR trim(address) = ''\n  GROUP BY platform\n) m ON m.platform = p.platform\nORDER BY \"Missing Address\" DESC;",
